{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@alfalab/core-components-env/tsconfig.base.json",
    "include": ["src", "src/**/*.json"],
    "exclude": ["**/*.stories.*", "**/*.test.*"],
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "ts-dist",
        "paths": {
            "@alfalab/core-components-scrollbar": ["../scrollbar/src"],
            "@alfalab/core-components-scrollbar/*": ["../scrollbar/src/*"],
            "@alfalab/core-components-scrollbar-private": ["./src"],
            "@alfalab/core-components-scrollbar-private/*": ["./src/*"]
        }
    },
    "references": [{ "path": "../scrollbar/tsconfig.build.json" }]
}
