{
  "packageName": "universal-modal",
  "displayName": "UniversalModal",
  "description": "Модальное окно. Используется для отображения контента в модальном слое.",
  "props": {
    "breakpoint": {
      "defaultValue": {
        "value": "1024"
      },
      "description": "Контрольная точка, с нее начинается desktop версия",
      "name": "breakpoint",
      "required": false,
      "type": {
        "name": "number | undefined"
      }
    },
    "defaultMatchMediaValue": {
      "defaultValue": null,
      "description": "Значение по-умолчанию для хука useMatchMedia",
      "name": "defaultMatchMediaValue",
      "required": false,
      "type": {
        "name": "boolean | (() => boolean) | undefined"
      }
    },
    "scrollableContainerRef": {
      "defaultValue": null,
      "description": "Реф контейнера на котором происходит scroll",
      "name": "scrollableContainerRef",
      "required": false,
      "type": {
        "name": "RefObject<HTMLDivElement> | undefined"
      }
    },
    "horizontalAlign": {
      "defaultValue": {
        "value": "center"
      },
      "description": "Расположение по горизонтали и сторона с которой модал “выезжает” при открытии",
      "name": "horizontalAlign",
      "required": false,
      "type": {
        "name": "\"start\" | \"end\" | \"center\" | undefined"
      }
    },
    "verticalAlign": {
      "defaultValue": {
        "value": "center"
      },
      "description": "Расположение модального окна по вертикали",
      "name": "verticalAlign",
      "required": false,
      "type": {
        "name": "\"center\" | \"top\" | \"bottom\" | undefined"
      }
    },
    "width": {
      "defaultValue": {
        "value": "500"
      },
      "description": "Ширина модального окна\nfullWidth - ширина модального окна подстроится под viewport\nminWidth - 500",
      "name": "width",
      "required": false,
      "type": {
        "name": "number | \"fullWidth\" | undefined"
      }
    },
    "height": {
      "defaultValue": null,
      "description": "Высота модального окна\nfullHeight - высота модального окна подстроится под viewport (по умолчанию для боковой модалки)\nhugContent - высота модального окна зафиксируется под размер содержимого (по умолчания для центральной модалки)\nminHeight - 264",
      "name": "height",
      "required": false,
      "type": {
        "name": "number | \"fullHeight\" | \"hugContent\" | undefined"
      }
    },
    "overlay": {
      "defaultValue": {
        "value": "true"
      },
      "description": "Наличие оверлея",
      "name": "overlay",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "margin": {
      "defaultValue": null,
      "description": "Устанавливает отступы модального окна",
      "name": "margin",
      "required": false,
      "type": {
        "name": "Margin | undefined"
      }
    },
    "open": {
      "defaultValue": null,
      "description": "Управление видимостью модалки",
      "name": "open",
      "required": true,
      "type": {
        "name": "boolean"
      }
    },
    "children": {
      "defaultValue": null,
      "description": "Контент",
      "name": "children",
      "required": false,
      "type": {
        "name": "ReactNode"
      }
    },
    "className": {
      "defaultValue": null,
      "description": "Дополнительный класс",
      "name": "className",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "dataTestId": {
      "defaultValue": null,
      "description": "Идентификатор для систем автоматизированного тестирования",
      "name": "dataTestId",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "onClose": {
      "defaultValue": null,
      "description": "Обработчик закрытия",
      "name": "onClose",
      "required": false,
      "type": {
        "name": "((event: MouseEvent<HTMLElement, MouseEvent> | KeyboardEvent<HTMLElement>, reason?: \"backdropClick\" | \"escapeKeyDown\" | \"closerClick\" | undefined) => void) | undefined"
      }
    },
    "backdropProps": {
      "defaultValue": null,
      "description": "Свойства для Бэкдропа",
      "name": "backdropProps",
      "required": false,
      "type": {
        "name": "(Partial<BackdropProps> & Record<string, unknown>) | undefined"
      }
    },
    "disableFocusLock": {
      "defaultValue": {
        "value": "false"
      },
      "description": "Отключает ловушку фокуса",
      "name": "disableFocusLock",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "disableBackdropClick": {
      "defaultValue": {
        "value": "false"
      },
      "description": "Отключает вызов `callback` при клике на бэкдроп",
      "name": "disableBackdropClick",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "wrapperClassName": {
      "defaultValue": null,
      "description": "Дополнительный класс для обертки (Modal)",
      "name": "wrapperClassName",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "transitionProps": {
      "defaultValue": null,
      "description": "Пропсы для анимации (CSSTransition)",
      "name": "transitionProps",
      "required": false,
      "type": {
        "name": "Partial<CSSTransitionProps> | undefined"
      }
    },
    "onUnmount": {
      "defaultValue": null,
      "description": "Обработчик события onExited компонента Transition",
      "name": "onUnmount",
      "required": false,
      "type": {
        "name": "(() => void) | undefined"
      }
    },
    "appearance": {
      "defaultValue": null,
      "description": "Сторона с которой будет появляться модальное окно",
      "name": "appearance",
      "required": false,
      "type": {
        "name": "\"right\" | \"bottom\" | undefined"
      }
    }
  },
  "demos": []
}