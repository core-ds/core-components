    "children": {
      "defaultValue": null,
      "description": "Дочерние элементы.",
      "name": "children",
      "required": false,
      "type": {
        "name": "ReactNode"
      }
    },
    "onMatchChange": {
      "defaultValue": null,
      "description": "Обработчик изменений в совпадении запросов",
      "name": "onMatchChange",
      "required": false,
      "type": {
        "name": "((isMatched: boolean) => void) | undefined"
