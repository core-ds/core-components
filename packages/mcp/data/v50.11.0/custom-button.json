      "name": "children",
      "required": false,
      "type": {
        "name": "ReactNode"
      }
    },
    "className": {
      "defaultValue": null,
      "description": "Дополнительный класс",
      "name": "className",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "dataTestId": {
