{
  "packageName": "tooltip",
  "displayName": "TooltipResponsive",
  "props": {
    "children": {
      "defaultValue": null,
      "description": "Дочерние элементы тултипа.\nПри срабатывании событий на них, тултип будет открываться",
      "name": "children",
      "required": true,
      "type": {
        "name": "ReactElement<any, string | JSXElementConstructor<any>>"
      }
    },
    "dataTestId": {
      "defaultValue": null,
      "description": "Идентификатор для систем автоматизированного тестирования",
      "name": "dataTestId",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "content": {
      "defaultValue": null,
      "description": "Контент тултипа",
      "name": "content",
      "required": true,
      "type": {
        "name": "ReactNode"
      }
    },
    "view": {
      "defaultValue": null,
      "description": "Вид тултипа",
      "name": "view",
      "required": false,
      "type": {
        "name": "\"tooltip\" | \"hint\" | undefined"
      }
    },
    "colors": {
      "defaultValue": null,
      "description": "Набор цветов для компонента",
      "name": "colors",
      "required": false,
      "type": {
        "name": "\"default\" | \"inverted\" | undefined"
      }
    },
    "open": {
      "defaultValue": null,
      "description": "Если `true`, то тултип будет открыт",
      "name": "open",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "contentClassName": {
      "defaultValue": null,
      "description": "Дополнительный класс для контента",
      "name": "contentClassName",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "zIndex": {
      "defaultValue": null,
      "description": "z-index компонента",
      "name": "zIndex",
      "required": false,
      "type": {
        "name": "number | undefined"
      }
    },
    "getPortalContainer": {
      "defaultValue": null,
      "description": "Функция, возвращающая контейнер, в который будет рендериться тултип",
      "name": "getPortalContainer",
      "required": false,
      "type": {
        "name": "(() => HTMLElement) | undefined"
      }
    },
    "popoverClassName": {
      "defaultValue": null,
      "description": "Дополнительный класс для поповера",
      "name": "popoverClassName",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "useAnchorWidth": {
      "defaultValue": null,
      "description": "Использовать ширину родительского элемента",
      "name": "useAnchorWidth",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "position": {
      "defaultValue": null,
      "description": "Позиционирование тултипа",
      "name": "position",
      "required": false,
      "type": {
        "name": "Position | undefined"
      }
    },
    "updatePopover": {
      "defaultValue": null,
      "description": "Хранит функцию, с помощью которой можно обновить положение компонента",
      "name": "updatePopover",
      "required": false,
      "type": {
        "name": "MutableRefObject<(() => void) | undefined> | undefined"
      }
    },
    "preventOverflow": {
      "defaultValue": null,
      "description": "Запрещает тултипу менять свою позицию, если он не влезает в видимую область.",
      "name": "preventOverflow",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "availableHeight": {
      "defaultValue": null,
      "description": "Позволяет тултипу подствраивать свою высоту под границы экрана, если из-за величины контента он выходит за рамки видимой области экрана",
      "name": "availableHeight",
      "required": false,
      "type": {
        "name": "boolean | (() => Element | null | undefined) | undefined"
      }
    },
    "offset": {
      "defaultValue": null,
      "description": "Смещение тултипа",
      "name": "offset",
      "required": false,
      "type": {
        "name": "[number, number] | undefined"
      }
    },
    "arrowClassName": {
      "defaultValue": null,
      "description": "Дополнительный класс для стрелочки",
      "name": "arrowClassName",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "withTransition": {
      "defaultValue": null,
      "description": "Показывать тултип с анимацией",
      "name": "withTransition",
      "required": false,
      "type": {
        "name": "boolean | undefined"
      }
    },
    "fallbackPlacements": {
      "defaultValue": null,
      "description": "Если тултип не помещается в переданной позиции (position), он попробует открыться в другой позиции,\nпо очереди для каждой позиции из этого списка.\nЕсли не передавать, то тултип открывается в противоположном направлении от переданного position.",
      "name": "fallbackPlacements",
      "required": false,
      "type": {
        "name": "Position[] | undefined"
      }
    },
    "onOpenDelay": {
      "defaultValue": null,
      "description": "Задержка перед открытием тултипа",
      "name": "onOpenDelay",
      "required": false,
      "type": {
        "name": "number | undefined"
      }
    },
    "onCloseDelay": {
      "defaultValue": null,
      "description": "Задержка перед закрытием тултипа",
      "name": "onCloseDelay",
      "required": false,
      "type": {
        "name": "number | undefined"
      }
    },
    "trigger": {
      "defaultValue": null,
      "description": "Событие, по которому происходит открытие тултипа",
      "name": "trigger",
      "required": false,
      "type": {
        "name": "Trigger | undefined"
      }
    },
    "targetClassName": {
      "defaultValue": null,
      "description": "Дополнительный класс для обертки над дочерними элементами",
      "name": "targetClassName",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "targetRef": {
      "defaultValue": null,
      "description": "Реф для обертки над дочерними элементами",
      "name": "targetRef",
      "required": false,
      "type": {
        "name": "MutableRefObject<HTMLElement | null> | undefined"
      }
    },
    "anchor": {
      "defaultValue": null,
      "description": "Элемент, относительно которого будет позиционировать тултип.",
      "name": "anchor",
      "required": false,
      "type": {
        "name": "RefElement | undefined"
      }
    },
    "targetTag": {
      "defaultValue": {
        "value": "div"
      },
      "description": "Тэг для target обертки",
      "name": "targetTag",
      "required": false,
      "type": {
        "name": "\"div\" | \"span\" | undefined"
      }
    },
    "onTargetClick": {
      "defaultValue": null,
      "description": "Обработчик клика по целевому элементу\nСобытие всплытия останавливается до вызова этого обработчика",
      "name": "onTargetClick",
      "required": false,
      "type": {
        "name": "((event: MouseEvent<HTMLElement, MouseEvent>) => void) | undefined"
      }
    },
    "onOpen": {
      "defaultValue": null,
      "description": "Обработчик открытия",
      "name": "onOpen",
      "required": false,
      "type": {
        "name": "((event?: MouseEvent<HTMLElement, MouseEvent> | undefined) => void) | undefined"
      }
    },
    "onClose": {
      "defaultValue": null,
      "description": "Обработчик закрытия",
      "name": "onClose",
      "required": false,
      "type": {
        "name": "((event?: MouseEvent<HTMLElement, MouseEvent> | undefined) => void) | undefined"
      }
    },
    "actionButtonTitle": {
      "defaultValue": null,
      "description": "Заголовок кнопки в футере",
      "name": "actionButtonTitle",
      "required": false,
      "type": {
        "name": "string | undefined"
      }
    },
    "bottomSheetProps": {
      "defaultValue": null,
      "description": "Дополнительные пропсы компонента BottomSheet",
      "name": "bottomSheetProps",
      "required": false,
      "type": {
        "name": "Partial<BottomSheetProps> | undefined"
      }
    },
    "breakpoint": {
      "defaultValue": {
        "value": "1024"
      },
      "description": "Контрольная точка, с нее начинается desktop версия",
      "name": "breakpoint",
      "required": false,
      "type": {
        "name": "number | undefined"
      }
    },
    "client": {
      "defaultValue": null,
      "description": "Версия, которая будет использоваться при серверном рендеринге",
      "name": "client",
      "required": false,
      "type": {
        "name": "\"desktop\" | \"mobile\" | undefined"
      }
    },
    "defaultMatchMediaValue": {
      "defaultValue": {
        "value": "client === undefined ? undefined : client === 'desktop'"
      },
      "description": "Значение по-умолчанию для хука useMatchMedia\n@deprecated Используйте client",
      "name": "defaultMatchMediaValue",
      "required": false,
      "type": {
        "name": "boolean | (() => boolean) | undefined"
      }
    }
  }
}