"demos": [
{
"title": "Примеры",
"description": "",
"desktop": "render(() => {\nconst [visible, setVisible] = React.useState(true);\n\nconst calendarStyles = {\nborder: '1px solid rgba(233, 233, 235, 1)',\nborderRadius: 'var(--calendar-popover-border-radius, var(--border-radius-16))',\nboxShadow: `0px 20px 24px rgba(0, 0, 0, 0.08),\n0px 12px 16px rgba(0, 0, 0, 0.04),\n0px 4px 8px rgba(0, 0, 0, 0.04),\n0px 0px 1px rgba(0, 0, 0, 0.04)`,\n};\n\nreturn (\n<div style={{ width: 344 }}>\n<div style={calendarStyles}>\n<CalendarWithSkeleton calendarVisible={visible} />\n</div>\n<Gap size={24}/>\n<Switch\nblock={true}\nchecked={!visible}\nlabel='Скелетонизация контента'\nonChange={() => setVisible(!visible)}\n/>\n</div>\n);\n});"
}
],
