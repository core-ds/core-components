"desktop": "<div>\n<Mq query='--mobile'>\n<Button breakpoint={BREAKPOINT} >Мобильная кнопка</Button>\n</Mq>\n<Mq query='--tablet-s'>\n<Button breakpoint={BREAKPOINT} >Десктопная кнопка</Button>\n</Mq>\n</div>"
}
],
