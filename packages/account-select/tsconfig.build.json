{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@alfalab/core-components-env/tsconfig.base.json",
    "include": ["src", "src/**/*.json"],
    "exclude": ["**/*.stories.*", "**/*.test.*"],
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "ts-dist",
        "paths": {
            "@alfalab/core-components-account-select": ["./src"],
            "@alfalab/core-components-account-select/*": ["./src/*"],
            "@alfalab/core-components-amount": ["../amount/src"],
            "@alfalab/core-components-amount/*": ["../amount/src/*"],
            "@alfalab/core-components-form-control": ["../form-control/src"],
            "@alfalab/core-components-form-control/*": ["../form-control/src/*"],
            "@alfalab/core-components-generic-wrapper": ["../generic-wrapper/src"],
            "@alfalab/core-components-generic-wrapper/*": ["../generic-wrapper/src/*"],
            "@alfalab/core-components-mq": ["../mq/src"],
            "@alfalab/core-components-mq/*": ["../mq/src/*"],
            "@alfalab/core-components-popover": ["../popover/src"],
            "@alfalab/core-components-popover/*": ["../popover/src/*"],
            "@alfalab/core-components-product-cover": ["../product-cover/src"],
            "@alfalab/core-components-product-cover/*": ["../product-cover/src/*"],
            "@alfalab/core-components-select": ["../select/src"],
            "@alfalab/core-components-select/*": ["../select/src/*"],
            "@alfalab/core-components-typography": ["../typography/src"],
            "@alfalab/core-components-typography/*": ["../typography/src/*"]
        }
    },
    "references": [
        { "path": "../amount/tsconfig.build.json" },
        { "path": "../form-control/tsconfig.build.json" },
        { "path": "../generic-wrapper/tsconfig.build.json" },
        { "path": "../mq/tsconfig.build.json" },
        { "path": "../popover/tsconfig.build.json" },
        { "path": "../product-cover/tsconfig.build.json" },
        { "path": "../select/tsconfig.build.json" },
        { "path": "../typography/tsconfig.build.json" }
    ]
}
