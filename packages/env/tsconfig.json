{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@alfalab/core-components-env/tsconfig.base.json",
    "include": ["src"],
    "compilerOptions": {
        "outDir": "dist",
        "paths": {
            "@alfalab/core-components-env": ["./src"],
            "@alfalab/core-components-env/*": ["./src/*"],
            "@alfalab/core-components-global-store": ["../global-store/src"],
            "@alfalab/core-components-global-store/*": ["../global-store/src/*"]
        }
    },
    "references": [{ "path": "../global-store" }]
}
